<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hóquei de Mesa</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/game/style.css">
    <link rel="stylesheet" href="/css/game/placar.css">
    <link rel="stylesheet" href="/css/game/disco.css">
    <link rel="stylesheet" href="/css/game/menu.css">
    <link rel="stylesheet" href="/css/game/superpoder.css">
    <link rel="stylesheet" href="/css/game/contador.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Hoquei de Mesa</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/about">Sobre</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/majors">Cursos</a>
                    </li>
                    {{#if user}}
                    <li class="nav-item">
                        <a class="nav-link" href="/">Jogar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/ranking">Ranking</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/logout">Logout ({{user.fullName}})</a>
                    </li>
                    {{else}}
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/register">Criar Conta</a>
                    </li>
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>

    <div class="menu" id="menuinicial">
        <h1 class="tituloMenu">HOQUEI</h1>

        <div class="inputs-nomes">
            <input type="text" id="inputNome1" placeholder="Jogador 1 (Esquerda)" maxlength="12" autocomplete="off">
            <input type="text" id="inputNome2" placeholder="Jogador 2 (Direita)" maxlength="12" autocomplete="off">
            <input type="number" id="inputLimitePontos" placeholder="Limite de Pontos" min="1" value="5" autocomplete="off">
        </div>

        <button class="buttonMenu" id="buttonIniciar">Jogar</button>

        <div id="historicoPartidas" style="margin-top: 20px; width: 80%; max-height: 200px; overflow-y: auto; background: rgba(0,0,0,0.1); padding: 10px; border-radius: 5px; font-size: 14px;">
            <h3 style="margin-top: 0; text-align: center;">Histórico de Partidas</h3>
            <ul id="listaHistorico" style="list-style: none; padding: 0;">
                <li style="text-align: center; color: #555;">Nenhuma partida registrada</li>
            </ul>
        </div>
    </div>

    <div class="menu" id="menujogo" style="display: none;">
        <h1 class="tituloMenu">Jogo Pausado</h1>
        <button class="buttonMenu" id="buttonReiniciar">Reiniciar</button>
        <button class="buttonMenu" id="buttonRetomar">Retomar</button>
        <button class="buttonMenu" id="buttonSair">Menu Inicial</button>
    </div>

    <div class="menu" id="menuvitoria" style="display: none; z-index: 400;">
        <h1 id="textoVitoria" class="tituloMenu">Jogador X Venceu!</h1>
        <button class="buttonMenu" id="buttonJogarNovamente">Jogar Novamente</button>
        <button class="buttonMenu" id="buttonVoltarMenu">Menu Inicial</button>
    </div>

    <div class="jogobox">
        <div class="placar">
            <div id="nomeDisplay1" class="nome-jogador">Jogador 1</div>
            <div id="pontuacao1" class="pontuacao">0</div>
            <div class="pontuacao">X</div>
            <div id="pontuacao2" class="pontuacao">0</div>
            <div id="nomeDisplay2" class="nome-jogador">Jogador 2</div>
        </div>

        <div class="jogo" id="jogo">
            <div class="contador" id="contador"></div>
            <div id="barra1" class="barra"></div>
            <div id="disco" class="disco"></div>
            <div id="barra2" class="barra"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/game/disco.js"></script>
    <script type="module" src="/js/game/barra.js"></script>
    <script type="module" src="/js/game/placar.js"></script>
    <script type="module" src="/js/game/superpoder.js"></script>
    <script type="module" src="/js/game/jogo.js"></script>
</body>
</html>
